{
  "name": "react-specter",
  "version": "0.1.0",
  "description": "Select-to-edit for React apps: click an element in your running dev app, describe the change in plain language, and your AI coding agent edits the real source file.",
  "keywords": [
    "react",
    "devtools",
    "inspector",
    "click-to-edit",
    "select-to-edit",
    "mcp",
    "claude-code",
    "ai",
    "vite-plugin",
    "nextjs",
    "webpack-loader",
    "babel-plugin"
  ],
  "license": "MIT",
  "author": "Mothil V <mothil@datagenie.ai>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Starkyv/react-specter.git"
  },
  "homepage": "https://github.com/Starkyv/react-specter#readme",
  "bugs": {
    "url": "https://github.com/Starkyv/react-specter/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=18.17"
  },
  "sideEffects": false,
  "bin": {
    "react-specter": "./bin/react-specter.mjs"
  },
  "files": [
    "dist",
    "bin",
    "bridge",
    "templates"
  ],
  "main": "./dist/overlay/index.cjs",
  "module": "./dist/overlay/index.js",
  "types": "./dist/overlay/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/overlay/index.d.ts",
        "default": "./dist/overlay/index.js"
      },
      "require": {
        "types": "./dist/overlay/index.d.cts",
        "default": "./dist/overlay/index.cjs"
      }
    },
    "./babel": {
      "import": {
        "types": "./dist/babel.d.ts",
        "default": "./dist/babel.js"
      },
      "require": {
        "types": "./dist/babel.d.cts",
        "default": "./dist/babel.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.ts",
        "default": "./dist/webpack.js"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      }
    },
    "./next": {
      "import": {
        "types": "./dist/next.d.ts",
        "default": "./dist/next.js"
      },
      "require": {
        "types": "./dist/next.d.cts",
        "default": "./dist/next.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@babel/core": "^7.26.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jsdom": "^26.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
